{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "momentum SkillResult",
  "type": "object",
  "required": [
    "skill_name",
    "skill_version",
    "symbol",
    "timeframe",
    "confidence",
    "evidence",
    "result",
    "degraded"
  ],
  "properties": {
    "skill_name": {
      "const": "momentum"
    },
    "skill_version": {
      "type": "string"
    },
    "symbol": {
      "type": "string"
    },
    "timeframe": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "result": {
      "type": "object"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "counter_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_condition": {
      "type": [
        "string",
        "null"
      ]
    },
    "degraded": {
      "type": "boolean"
    },
    "degraded_reason": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
