{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GADecision",
  "type": "object",
  "required": ["symbol", "decision", "signal_grade", "confidence", "summary", "counter_evidence", "has_trade_plan", "suggested_actions", "risk_notes"],
  "properties": {
    "symbol": {"type": "string"},
    "decision": {
      "type": "string",
      "enum": ["trade_plan_available", "wait_for_pullback", "wait_for_breakout", "wait_for_reclaim", "avoid_chop", "no_edge", "monitor_only"]
    },
    "signal_grade": {"type": "string", "enum": ["S", "A", "B", "C", "D"]},
    "market_bias": {"type": "string", "enum": ["bullish", "bearish", "neutral", "mixed"]},
    "trend_stage": {"type": "string", "enum": ["early", "middle", "late", "range", "transition", "unknown"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "summary": {"type": "string"},
    "evidence": {"type": "array", "items": {"type": "string"}},
    "counter_evidence": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "risk_notes": {"type": "array", "items": {"type": "string"}},
    "has_trade_plan": {"type": "boolean"},
    "trade_plan": {
      "type": ["object", "null"],
      "properties": {
        "side": {"type": "string", "enum": ["LONG", "SHORT"]},
        "entry_type": {"type": "string", "enum": ["market", "limit", "trigger"]},
        "entry_price": {"type": ["number", "null"]},
        "trigger_price": {"type": ["number", "null"]},
        "stop_loss": {"type": "number"},
        "take_profits": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["price", "ratio"],
            "properties": {
              "price": {"type": "number"},
              "ratio": {"type": "number"}
            }
          }
        },
        "risk_percent": {"type": "number"},
        "invalid_condition": {"type": "string"},
        "reason": {"type": "string"}
      }
    },
    "opportunity_watch": {
      "type": ["object", "null"],
      "properties": {
        "needed": {"type": "boolean"},
        "direction": {"type": ["string", "null"], "enum": ["LONG", "SHORT", null]},
        "reason": {"type": ["string", "null"]},
        "conditions": {"type": "array"},
        "invalid_condition": {"type": ["object", "string", "null"]},
        "expires_minutes": {"type": ["integer", "null"]}
      }
    },
    "suggested_actions": {
      "type": "array",
      "items": {"type": "string", "enum": ["create_paper_order", "create_opportunity_watch", "add_to_watchlist", "ignore"]}
    }
  }
}
